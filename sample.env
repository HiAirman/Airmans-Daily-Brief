# Copy this file to .env and fill in secrets/overrides
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=YOUR_SENDER_EMAIL_ADDRESS
SMTP_PASSWORD=YOUR_APP_PASSWORD
SMTP_SENDER_NAME="AIRMAN'S Daily Brief"
SMTP_RECIPIENT=YOUR_RECEIPIENT_EMAIL

NYT_API_KEY=YOUR_API_KEY
NYT_ENDPOINT=https://api.nytimes.com/svc/mostpopular/v2/shared/1/facebook.json
OPENMETEO_LAT=31.2304
OPENMETEO_LON=121.4737
TIMEZONE=Asia/Shanghai
